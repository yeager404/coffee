# ── PostgreSQL ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=55432
DB_NAME=coffee_db
DB_USER=postgres
DB_PASSWORD=password

# ── RabbitMQ ─────────────────────────────────────────────────────
RABBIT_HOST=localhost
RABBIT_PORT=55672
RABBIT_USER=guest
RABBIT_PASSWORD=guest
RABBIT_VHOST=/

# ── Model ────────────────────────────────────────────────────────
MODEL_PATH=models/demand_model.pkl
RETRAIN_INTERVAL_H=6
MIN_TRAIN_ROWS=50
FORECAST_DAYS=14
